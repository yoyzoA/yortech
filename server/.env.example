# ──────────────────────────────────────────────────────────────────────────────
# YorTech Server — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in every value below
#   3. NEVER commit .env to git — it is already in .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Get this from: console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Get this from: neon.tech → Your Project → Connection Details → Pooled connection
# Make sure to use the POOLED connection string (ends in -pooler.us-east-1.aws.neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── NewsAPI ───────────────────────────────────────────────────────────────────
# Get this from: newsapi.org → Get API Key (free account)
NEWSAPI_KEY=your-newsapi-key-here

# ── Pexels API ────────────────────────────────────────────────────────────────
# Get this from: pexels.com/api → Your API Key (free account)
PEXELS_API_KEY=your-pexels-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Change NODE_ENV to "production" on your EC2 instance
